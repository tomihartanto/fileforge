# FileForge - Environment Variables
# Salin file ini ke .env (local) atau .env.production (production)

# Database PostgreSQL
# Local: postgresql://user:password@localhost:5432/dbname?schema=public
# Neon:  postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=""

# Storage: "local" (simpan ke assets/uploads/) atau "cloudinary" (CDN)
STORAGE_DRIVER="local"

# Cloudinary (wajib jika STORAGE_DRIVER="cloudinary")
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_FOLDER="FileForge"
